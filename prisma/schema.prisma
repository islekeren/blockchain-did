generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Issuer {
  id            String       @id @default(cuid())
  name          String
  did           String       @unique
  walletAddress String       @unique
  trusted       Boolean      @default(false)
  students      Student[]
  credentials   Credential[]
  users         User[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Student {
  id            String       @id @default(cuid())
  name          String
  studentNo     String       @unique
  department    String
  universityId  String
  university    Issuer       @relation(fields: [universityId], references: [id], onDelete: Restrict)
  walletAddress String       @unique
  active        Boolean      @default(true)
  credentials   Credential[]
  users         User[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([universityId])
}

model User {
  id             String     @id @default(cuid())
  walletAddress  String     @unique
  role           String
  issuerId       String?
  issuer         Issuer?    @relation(fields: [issuerId], references: [id], onDelete: SetNull)
  studentId      String?
  student        Student?   @relation(fields: [studentId], references: [id], onDelete: SetNull)
  verifierName   String?
  nonce          String?
  nonceExpiresAt DateTime?
  lastLoginAt    DateTime?
  auditLogs      AuditLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([role])
  @@index([issuerId])
  @@index([studentId])
}

model Credential {
  id             String       @id @default(cuid())
  credentialId   String       @unique
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuerId       String
  issuer         Issuer       @relation(fields: [issuerId], references: [id], onDelete: Restrict)
  type           String       @default("StudentCredential")
  schemaName     String       @default("StudentCredential")
  credentialJson String
  credentialHash String?
  status         String       @default("PENDING_ONCHAIN")
  issuedAt       DateTime
  expiresAt      DateTime
  registeredAt   DateTime?
  registeredTxHash String?
  revokedAt      DateTime?
  revocationTxHash String?
  revocationReason String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([studentId])
  @@index([issuerId])
  @@index([credentialId])
}

model VerificationRequest {
  id                 String              @id @default(cuid())
  credentialId       String?
  verifierName       String
  nonce              String?             @unique
  challengeMessage   String?
  result             String              @default("PENDING")
  reasons            String
  used               Boolean             @default(false)
  expiresAt          DateTime?
  presentationProofs PresentationProof[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([credentialId])
  @@index([used])
}

model PresentationProof {
  id                   String              @id @default(cuid())
  credentialId         String
  credentialHash       String
  studentWalletAddress String
  requestId            String
  request              VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  nonce                String
  verifierName         String
  message              String
  signature            String
  createdAt            DateTime            @default(now())

  @@index([credentialId])
  @@index([requestId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorWallet   String?
  actorRole     String?
  action        String
  targetType    String
  targetId      String?
  txHash        String?
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
