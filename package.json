{
  "name": "decentralized-student-verification-wallet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "hardhat test",
    "test:gas": "hardhat test test/GasEfficiency.test.ts",
    "format": "prettier --write .",
    "hardhat:compile": "hardhat compile",
    "hardhat:test": "hardhat test",
    "hardhat:node": "hardhat node",
    "hardhat:deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "db:generate": "prisma generate",
    "db:migrate": "RUST_LOG=trace prisma migrate dev",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:reset": "RUST_LOG=trace prisma migrate reset --force"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@prisma/client": "^6.10.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethers": "^6.13.7",
    "lucide-react": "^0.468.0",
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
